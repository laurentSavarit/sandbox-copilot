# Copy this file to .env and fill in your GitHub token.
# The token needs the "Copilot Requests" permission (fine-grained PAT)
# or a classic token with the `copilot` scope.
#
# Precedence inside the container: COPILOT_GITHUB_TOKEN > GH_TOKEN > GITHUB_TOKEN

COPILOT_GITHUB_TOKEN=ghp_your_token_here
